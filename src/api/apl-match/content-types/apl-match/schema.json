{
  "kind": "collectionType",
  "collectionName": "apl_matches",
  "info": {
    "singularName": "apl-match",
    "pluralName": "apl-matches",
    "displayName": "APL Matches",
    "description": ""
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "team_a": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::apl-team.apl-team",
      "inversedBy": "matches_as_team_a"
    },
    "team_b": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::apl-team.apl-team",
      "inversedBy": "matches_as_team_b"
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "upcoming",
        "live",
        "completed"
      ],
      "default": "upcoming"
    },
    "team_a_score": {
      "type": "integer",
      "default": 0
    },
    "team_b_score": {
      "type": "integer",
      "default": 0
    },
    "start_time": {
      "type": "datetime"
    },
    "period": {
      "type": "enumeration",
      "enum": [
        "not_started",
        "first_half",
        "half_time",
        "second_half",
        "extra_time_first",
        "extra_time_second",
        "penalty_shootout",
        "full_time"
      ],
      "default": "not_started"
    },
    "period_start_time": {
      "type": "datetime"
    },
    "stoppage_time": {
      "type": "integer",
      "default": 0
    },
    "goal_events": {
      "type": "component",
      "repeatable": true,
      "component": "match.goal-event"
    },
    "card_events": {
      "type": "component",
      "repeatable": true,
      "component": "match.card-event"
    },
    "substitution_events": {
      "type": "component",
      "repeatable": true,
      "component": "match.substitution-event"
    },
    "save_events": {
      "type": "component",
      "repeatable": true,
      "component": "match.save-event"
    },
    "round": {
      "type": "enumeration",
      "enum": [
        "group_stage",
        "round_of_16",
        "quarter_final",
        "semi_final",
        "final"
      ]
    },
    "match_number": {
      "type": "integer"
    },
    "team_a_starting_player_count": {
      "type": "integer",
      "default": 10,
      "min": 8,
      "max": 10
    },
    "team_b_starting_player_count": {
      "type": "integer",
      "default": 10,
      "min": 8,
      "max": 10
    },
    "team_a_starters": {
      "type": "json",
      "default": []
    },
    "team_b_starters": {
      "type": "json",
      "default": []
    }
  }
}
