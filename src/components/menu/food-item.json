        "Snacks",
        "Main Course",
        "Beverages",
        "Coffee",
        "Desserts",
        "Pizza",
        "Rolls",
        "Sides",
        "Pasta",
        "Juices",
        "Smoothies",
        "Healthy",
        "Wraps"
      ],
      "required": true
    },
    "calories": {
      "type": "integer"
    },
    "foodType": {
      "type": "enumeration",
      "enum": [
        "veg",
        "non-veg",
        "egg"
      ],
      "required": true,
      "default": "veg"
    },
    "allergens": {
      "type": "string",
